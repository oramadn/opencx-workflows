# Express + pg (existing)
DATABASE_URL=postgresql://postgres:password@localhost:5432/workflows

# OpenAI — required for the workflow builder LLM generation
OPENAI_API_KEY=sk-your-key-here

# Workflow DevKit — Postgres world (https://useworkflow.dev/worlds/postgres)
# Required when using workflows. If omitted, WORKFLOW_POSTGRES_URL falls back to DATABASE_URL.
WORKFLOW_TARGET_WORLD=@workflow/world-postgres
WORKFLOW_POSTGRES_URL=postgresql://postgres:password@localhost:5432/workflows
