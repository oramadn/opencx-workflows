# Express + pg (existing)
DATABASE_URL=postgresql://postgres:12345@localhost:5432/workflows

# OpenAI — required for the workflow builder LLM generation
OPENAI_API_KEY=sk-your-key-here

# E2B — sandboxed execution of AI-generated workflow code (https://e2b.dev/)
# Sign up at e2b.dev, grab your API key from the dashboard (Hobby tier includes $100 credits).
E2B_API_KEY=e2b_your_key_here

# Resend — email delivery for the sendEmail workflow tool (https://resend.com/)
# Sign up at resend.com, grab your API key from the dashboard.
# RESEND_FROM_EMAIL defaults to onboarding@resend.dev (Resend's test sender) if unset.
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Slack — channel messaging for the sendSlackChannelMessage workflow tool
# Create a Slack app at api.slack.com/apps, add the chat:write scope, install to your
# workspace, and paste the Bot User OAuth Token (xoxb-...) below.
# Without it, sendSlackChannelMessage falls back to a console.log stub.
SLACK_BOT_TOKEN=xoxb-your-token-here

# Workflow data tools — host-backed DB queries for getSessions / getMessages
# The harness inside E2B calls back to this URL to run real DB queries.
# E2B sandboxes cannot reach localhost — use a tunnel (ngrok, cloudflared) or
# a deployed URL that points to your backend.
# Without these, data tools return mock arrays.
WORKFLOW_TOOLS_BASE_URL=https://your-tunnel-or-deployed-url.example.com
WORKFLOW_TOOLS_SECRET=0dcaee7e8e929d75f939f4537dbbc5d2240bdd4ddb3cba5bf9d6d02143533889

# Workflow DevKit — Postgres world (https://useworkflow.dev/worlds/postgres)
# Required when using workflows. If omitted, WORKFLOW_POSTGRES_URL falls back to DATABASE_URL.
WORKFLOW_TARGET_WORLD=@workflow/world-postgres
WORKFLOW_POSTGRES_URL=postgresql://postgres:12345@localhost:5432/workflows
