{
  "name": "workflows",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "backend": "pnpm --filter @workflows/backend start",
    "backend:dev": "pnpm --filter @workflows/backend dev",
    "frontend": "pnpm --filter @workflows/frontend dev",
    "frontend:build": "pnpm --filter @workflows/frontend build",
    "frontend:preview": "pnpm --filter @workflows/frontend preview",
    "worker": "pnpm --filter @workflows/worker start",
    "worker:dev": "pnpm --filter @workflows/worker dev",
    "worker:migrate": "pnpm --filter @workflows/worker migrate"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2"
  }
}
